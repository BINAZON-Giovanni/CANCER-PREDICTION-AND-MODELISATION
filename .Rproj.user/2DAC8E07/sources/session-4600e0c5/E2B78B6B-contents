varUniQuanti <- function(variable, 
                         titreGraph = "DensitÃĐ", 
                         titreX = "Variable",
                         show_hist = TRUE, 
                         show_mean = TRUE, 
                         show_median = TRUE,
                         col_fill = "#4C72B0", 
                         col_line = "#2A4E6E") {
  
  dens <- density(variable, na.rm = TRUE)
  

  if (show_hist) {
    hist(variable,
         freq = FALSE,
         col = adjustcolor(col_fill, alpha.f = 0.3),
         border = "white",
         main = titreGraph,
         xlab = titreX)
    lines(dens, lwd = 2, col = col_line)
  } else {
    plot(dens,
         main = titreGraph,
         xlab = titreX,
         lwd = 2,
         col = col_line)
  }
  

  if (show_mean) {
    abline(v = mean(variable, na.rm = TRUE),
           col = "#D55E00", lwd = 2, lty = 2)
  }
  

  if (show_median) {
    abline(v = median(variable, na.rm = TRUE),
           col = "#009E73", lwd = 2, lty = 3)
  }
  

  legend("topright",
         legend = c("Moyenne", "MÃĐdiane"),
         col = c("#D55E00", "#009E73"),
         lty = c(2, 3),
         lwd = 2,
         bty = "n")
  
  q <- quantile(variable, probs = seq(0, 1, by = 0.01), na.rm = TRUE)
  return(q)
}




