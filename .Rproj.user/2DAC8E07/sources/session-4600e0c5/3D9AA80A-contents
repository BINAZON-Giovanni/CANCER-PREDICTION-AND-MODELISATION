varUniQuanti <- function(variable, titreGraph, titreX) {
  
  dens <- density(variable)

  plot(dens,
       main = titreGraph,
       xlab = titreX)
  
  q <- quantile(variable, probs = seq(0.01, 0.99, by = 0.01))
  return(q)
}


