# ---- Analyse Multivarié : ACP ----
# ==================================================== #
donnees$fumeur<- as.factor(donnees$fumeur)
str(donnees)
acp_dataset= donnees%>%select(poidsEnfant,Age,poidsMere,Gestation)

install.packages("FactoMineR")
library(FactoMineR)
library(factoextra)   # pour les graphiques (optionnel mais très utile)

res_pca <- PCA(acp_dataset, scale.unit = TRUE, ncp = 4, graph = FALSE)

res_pca$eig  #En règle général, on garde les composantes qui expliquent au moins 70 % de l’inertie cumulée.

# Analyser la distribution des composantes
coord <- res_pca$ind$coord
head(coord)
par(mfrow = c(1,2))
hist(coord[,1], main = "Distribution de la composante 1", xlab = "Dim 1")
hist(coord[,2], main = "Distribution de la composante 2", xlab = "Dim 2")
hist(coord[,3], main = "Distribution de la composante 3", xlab = "Dim 3")
hist(coord[,4], main = "Distribution de la composante 4", xlab = "Dim 4")
par(mfrow = c(1,1))

#Identifier les valeurs atypiques 

z1 <- scale(coord[,1])
z2 <- scale(coord[,2])

ind_atypiques <- (abs(z1) > 3) | (abs(z2) > 3)

donnees_atypiques_acp <- donnees[ind_atypiques, ]
